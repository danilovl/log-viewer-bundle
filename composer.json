{
    "name": "danilovl/log-viewer-bundle",
    "description": "A Symfony bundle for log viewer",
    "type": "symfony-bundle",
    "keywords": ["php","symfony","bundle"],
    "license": "MIT",
    "authors": [
        {
            "name": "Vladimir Danilov"
        }
    ],
    "require": {
        "php": "^8.5",
        "symfony/asset": "^8.0",
        "symfony/framework-bundle": "^8.0",
        "symfony/notifier": "^8.0",
        "symfony/process": "^8.0",
        "symfony/twig-bundle": "^8.0",
        "symfony/yaml": "^8.0"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.92.5",
        "phpstan/extension-installer": "^1.4.3",
        "phpstan/phpstan": "^2.1.33",
        "phpstan/phpstan-symfony": "^2.0.9",
        "phpunit/phpunit": "^12.0",
        "symfony/google-chat-notifier": "^8.0",
        "symfony/http-client": "^8.0",
        "symfony/security-bundle": "8.0.*",
        "symfony/slack-notifier": "^8.0",
        "symfony/telegram-notifier": "^8.0"
    },
    "autoload": {
        "psr-4": {
            "Danilovl\\LogViewerBundle\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Danilovl\\LogViewerBundle\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "tests": "vendor/bin/phpunit tests/Unit tests/Integration tests/Go",
        "phpstan": "phpstan analyse -c phpstan.neon src tests --no-progress",
        "phpstan-generate-baseline": "@php vendor/bin/phpstan analyse --level 9  --configuration phpstan.neon  src/ tests/ --generate-baseline",
        "cs-fixer": "vendor/bin/php-cs-fixer fix --allow-risky=yes",
        "cs-fixer-check": "vendor/bin/php-cs-fixer fix --dry-run --allow-risky=yes"
    },
    "config": {
        "allow-plugins": {
            "phpstan/extension-installer": true
        },
        "sort-packages": true
    }
}
